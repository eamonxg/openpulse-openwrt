#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/pulse-server

generate_token() {
	local tok
	tok=$(cat /proc/sys/kernel/random/uuid 2>/dev/null | tr -d '-')
	[ -z "$tok" ] && tok=$(dd if=/dev/urandom bs=16 count=1 2>/dev/null | hexdump -v -e '"%02x"')
	echo "$tok"
}

start_service() {
	local enabled port token lan_ip

	config_load pulse-server
	config_get enabled config enabled '1'
	config_get port config port '6688'
	config_get token config token ''

	[ "$enabled" = "1" ] || return 0

	if [ -z "$token" ]; then
		token=$(generate_token)
		uci set pulse-server.config.token="$token"
		uci commit pulse-server
		logger -t pulse-server "Generated API token"
	fi

	lan_ip=$(ubus call network.interface.lan status 2>/dev/null |
		jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)
	[ -z "$lan_ip" ] && lan_ip="0.0.0.0"

	procd_open_instance
	procd_set_param command "$PROG"
	procd_append_param command --addr "${lan_ip}:${port}"
	procd_append_param command --token "${token}"
	procd_set_param respawn
	procd_close_instance

	logger -t pulse-server "Listening on ${lan_ip}:${port}"
}

service_triggers() {
	procd_add_reload_trigger pulse-server
}
